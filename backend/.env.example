# RoadBrief Backend Environment Variables
# Copy to .env and update for your environment

# Database URL (fly.io provisions this automatically)
DATABASE_URL=postgresql+psycopg2://roadbrief:roadbrief@localhost:5432/roadbrief

# JWT secret for token signing — REQUIRED
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# Mapbox token for map rendering (get one at https://mapbox.com)
MAPBOX_TOKEN=

# CORS origins (comma-separated, use https:// in production)
# CORS_ORIGINS=https://roadbrief-web.fly.dev

# Set to "production" to enable HSTS
# ROADBRIEF_ENV=production

# Set to "true" to enable SQL query logging (NEVER in production)
# DEBUG=true
